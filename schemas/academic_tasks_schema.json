{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Academic Task",
  "type": "object",
  "properties": {
    "id": { "type": "integer" },
    "subject_id": { "type": "integer" },
    "titulo": { "type": "string" },
    "descricao": { "type": "string" },
    "data_prevista": { "type": "string", "format": "date" },
    "status": {
      "type": "string",
      "enum": ["pendente", "em andamento", "concluida"]
    }
  },
  "required": ["id", "subject_id", "titulo", "status"]
}
